#!/usr/bin/env bash
# Bootstrap wrapper for the ccreplay MCP server.
#
# Creates .venv on first run, installs/refreshes dependencies when
# requirements.txt changes, then execs the Python MCP server.
#
# All bootstrap output goes to stderr because the MCP client reads
# stdout as JSON-RPC framing — any stray byte there breaks the protocol.

set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
VENV="$ROOT/.venv"
REQS="$ROOT/requirements.txt"
STAMP="$VENV/.requirements.stamp"

if [ ! -x "$VENV/bin/python" ]; then
  python3 -m venv "$VENV" >&2
fi

if [ ! -f "$STAMP" ] || [ "$REQS" -nt "$STAMP" ]; then
  "$VENV/bin/pip" install -q --upgrade pip >&2
  "$VENV/bin/pip" install -q -r "$REQS" >&2
  touch "$STAMP"
fi

export PYTHONPATH="$ROOT${PYTHONPATH:+:$PYTHONPATH}"
exec "$VENV/bin/python" -m ccreplay_mcp "$@"
